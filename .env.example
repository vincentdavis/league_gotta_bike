# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
INTERNAL_IPS=127.0.0.1
DJANGO_PORT=8002

# Email Configuration (django-anymail with Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Tests
TEST_TO_EMAIL=to_me@example.com

# Logfire Configuration (optional for local development)
# Get your token from https://logfire.pydantic.dev/
# Leave empty for local development to use console-only logging
LOGFIRE_TOKEN=

# Database (optional, defaults to SQLite)
# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Media and Static (optional, uses defaults)
# MEDIA_ROOT=media
# STATIC_ROOT=staticfiles
